# === RENOMBRAR ESTE ARCHIVO A .env ANTES DE USAR ===
# API key de OpenAI (gpt-4o-mini): https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXX
NODE_ENV=production
PORT=3000

# Multi-tenant: define tenants and their shared keys (JSON)
# Example:
# TENANTS={"ispA":{"key":"dev-ispA-key"},"ispB":{"key":"dev-ispB-key"}}
TENANTS={"ispA":{"key":"dev-ispA-key"}}